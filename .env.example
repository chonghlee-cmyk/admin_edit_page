# ============================================================
# GOOGLE SHEETS
# ============================================================
# Google 서비스 계정 JSON 키 파일 경로 (로컬 개발용)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# 구글 스프레드시트 ID
SPREADSHEET_ID=your_spreadsheet_id_here

# 데이터 출력 탭 이름
TARGET_SHEET_NAME=관리자 설정

# 동기화 로그 탭 이름
SYNC_LOG_TAB=관리자 설정 로그

# ============================================================
# ADMIN SITE
# ============================================================
ADMIN_BASE_URL=https://your-admin-site.com
ADMIN_ID=your_admin_id
ADMIN_PASSWORD=your_admin_password
